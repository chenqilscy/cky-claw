{
  "name": "kasaya-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "npx playwright test --config=playwright.e2e.config.ts",
    "test:e2e:provider": "npx playwright test --config=playwright.e2e.config.ts --project=provider-tests",
    "test:e2e:agent": "npx playwright test --config=playwright.e2e.config.ts --project=agent-tests",
    "test:e2e:chat": "npx playwright test --config=playwright.e2e.config.ts --project=chat-tests",
    "test:e2e:skill": "npx playwright test --config=playwright.e2e.config.ts --project=skill-tests",
    "test:e2e:kb": "npx playwright test --config=playwright.e2e.config.ts --project=kb-tests",
    "test:e2e:headed": "npx playwright test --config=playwright.e2e.config.ts --headed",
    "test:e2e:debug": "npx playwright test --config=playwright.e2e.config.ts --debug"
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "@ant-design/pro-components": "^2.7.0",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@dagrejs/dagre": "^3.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone": "^2.6.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/instrumentation-fetch": "^0.214.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@tanstack/react-query": "^5.51.0",
    "@xyflow/react": "^12.10.2",
    "antd": "^5.20.0",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.0"
