# Kasaya 环境变量配置
# 复制此文件为 .env 并修改对应值
# cp .env.example .env

# ============ 数据库 ============
# PostgreSQL 密码（docker-compose 和 backend 共用）
POSTGRES_PASSWORD=kasaya_dev

# ============ 后端服务 ============
# 数据库连接（Docker 内部网络使用 db 作为主机名）
KASAYA_DATABASE_URL=postgresql+asyncpg://kasaya:kasaya_dev@db:5432/kasaya

# Redis 连接
KASAYA_REDIS_URL=redis://redis:6379/0

# JWT 密钥（生产环境必须更换为随机强密钥）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
KASAYA_SECRET_KEY=dev-secret-key-change-in-production

# JWT Token 过期时间（分钟），默认 1440（24小时）
KASAYA_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 调试模式（生产环境设为 false）
KASAYA_DEBUG=true

# CORS 允许的域名（逗号分隔）
# KASAYA_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============ 可观测性（OTel）============
# 启用 OpenTelemetry（需要安装 OTel 依赖包）
KASAYA_OTEL_ENABLED=false

# OTel 服务名称
KASAYA_OTEL_SERVICE_NAME=kasaya-backend

# OTel OTLP 导出端点（Jaeger / OTel Collector gRPC）
KASAYA_OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# ============ OAuth 2.0 SSO ============
# GitHub
KASAYA_OAUTH_GITHUB_CLIENT_ID=
KASAYA_OAUTH_GITHUB_CLIENT_SECRET=
KASAYA_OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# 企微 (WeCom)
KASAYA_OAUTH_WECOM_CORP_ID=
KASAYA_OAUTH_WECOM_AGENT_ID=
KASAYA_OAUTH_WECOM_SECRET=

# 钉钉 (DingTalk)
KASAYA_OAUTH_DINGTALK_CLIENT_ID=
KASAYA_OAUTH_DINGTALK_CLIENT_SECRET=

# 飞书 (Feishu)
KASAYA_OAUTH_FEISHU_APP_ID=
KASAYA_OAUTH_FEISHU_APP_SECRET=

# OIDC (Keycloak / Casdoor / 通用 OIDC Provider)
KASAYA_OAUTH_OIDC_ISSUER=
KASAYA_OAUTH_OIDC_CLIENT_ID=
KASAYA_OAUTH_OIDC_CLIENT_SECRET=
KASAYA_OAUTH_OIDC_SCOPE=openid profile email

# Google OAuth
KASAYA_OAUTH_GOOGLE_CLIENT_ID=
KASAYA_OAUTH_GOOGLE_CLIENT_SECRET=
KASAYA_OAUTH_GOOGLE_SCOPE=openid profile email
