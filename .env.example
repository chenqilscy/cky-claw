# CkyClaw 环境变量配置
# 复制此文件为 .env 并修改对应值
# cp .env.example .env

# ============ 数据库 ============
# PostgreSQL 密码（docker-compose 和 backend 共用）
POSTGRES_PASSWORD=ckyclaw_dev

# ============ 后端服务 ============
# 数据库连接（Docker 内部网络使用 db 作为主机名）
CKYCLAW_DATABASE_URL=postgresql+asyncpg://ckyclaw:ckyclaw_dev@db:5432/ckyclaw

# Redis 连接
CKYCLAW_REDIS_URL=redis://redis:6379/0

# JWT 密钥（生产环境必须更换为随机强密钥）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(64))"
CKYCLAW_SECRET_KEY=dev-secret-key-change-in-production

# JWT Token 过期时间（分钟），默认 1440（24小时）
CKYCLAW_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 调试模式（生产环境设为 false）
CKYCLAW_DEBUG=true

# CORS 允许的域名（逗号分隔）
# CKYCLAW_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============ 可观测性（OTel）============
# 启用 OpenTelemetry（需要安装 OTel 依赖包）
CKYCLAW_OTEL_ENABLED=false

# OTel 服务名称
CKYCLAW_OTEL_SERVICE_NAME=ckyclaw-backend

# OTel OTLP 导出端点（Jaeger / OTel Collector gRPC）
CKYCLAW_OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# ============ OAuth 2.0 SSO ============
# GitHub
CKYCLAW_OAUTH_GITHUB_CLIENT_ID=
CKYCLAW_OAUTH_GITHUB_CLIENT_SECRET=
CKYCLAW_OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# 企微 (WeCom)
CKYCLAW_OAUTH_WECOM_CORP_ID=
CKYCLAW_OAUTH_WECOM_AGENT_ID=
CKYCLAW_OAUTH_WECOM_SECRET=

# 钉钉 (DingTalk)
CKYCLAW_OAUTH_DINGTALK_CLIENT_ID=
CKYCLAW_OAUTH_DINGTALK_CLIENT_SECRET=

# 飞书 (Feishu)
CKYCLAW_OAUTH_FEISHU_APP_ID=
CKYCLAW_OAUTH_FEISHU_APP_SECRET=
